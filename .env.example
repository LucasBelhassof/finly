# Runtime
NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/finly
APP_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3001

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
AUTH_REFRESH_COOKIE_NAME=finance_rt
PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password

# Import AI
IMPORT_AI_ENABLED=false
IMPORT_AI_MODE=direct
IMPORT_AI_PROVIDER=openai
IMPORT_AI_MODEL=
IMPORT_AI_TIMEOUT_MS=8000
IMPORT_AI_AUTO_APPLY_THRESHOLD=0.8
IMPORT_AI_MAX_ROWS_PER_REQUEST=100
IMPORT_AI_WEBHOOK_URL=

# Chat AI
CHAT_AI_ENABLED=false
CHAT_AI_PROVIDER=gemini
CHAT_AI_MODEL=
CHAT_AI_TIMEOUT_MS=12000
CHAT_AI_MAX_RESPONSE_TOKENS=2000
CHAT_AI_PRICING_GEMINI_INPUT_PER_MILLION=
CHAT_AI_PRICING_GEMINI_OUTPUT_PER_MILLION=
CHAT_AI_PRICING_OPENAI_INPUT_PER_MILLION=
CHAT_AI_PRICING_OPENAI_OUTPUT_PER_MILLION=

# Provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=
